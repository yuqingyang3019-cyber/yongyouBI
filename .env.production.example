# This file is a production template. Copy it to /opt/yongyou-bi/.env on the ECS
# and replace every change-me value. Do not commit that .env file.

YONBIP_APP_KEY=
YONBIP_APP_SECRET=
YONBIP_GATEWAY_URL=https://c3.yonyoucloud.com/iuap-api-gateway
YONBIP_TOKEN_URL=https://c3.yonyoucloud.com/iuap-api-gateway
YONBIP_PAGE_SIZE=200
YONBIP_MAX_PAGES=50
YONBIP_CONTRACT_DETAIL_INTERVAL=1.5

# Docker service name "postgres" is intentional.
RECEIVABLE_DATABASE_URL=postgresql://yongyou_app:change-me@postgres:5432/yongyou_receivables
RECEIVABLE_DB_NAME=yongyou_receivables
RECEIVABLE_DB_USER=yongyou_app
RECEIVABLE_DB_PASSWORD=change-me
RECEIVABLE_DB_POOL_SIZE=4

DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_CORP_ID=
DINGTALK_ROBOT_CODE=
DINGTALK_CONTACT_CACHE_DB=/data/contact-cache.sqlite
DINGTALK_CONTACT_CACHE_TTL_HOURS=6
RECEIVABLE_NOTIFICATION_DB=/data/notification-tasks.sqlite
RECEIVABLE_NOTIFY_INCLUDE_UPCOMING=true
RECEIVABLE_NOTIFY_TOP_N=15

# Replace with the final HTTPS domain before enabling DingTalk login.
ALLOWED_ORIGINS=https://receivables.example.com
APP_SESSION_SECRET=change-me-to-a-random-32-byte-secret
SESSION_TTL_SECONDS=604800
COOKIE_SECURE=true
DINGTALK_LOGIN_ENABLED=true
ALLOW_BROWSER_LOGIN=false

# Configure after SQLBot has been initialized and a dedicated HTTPS host is available.
SQLBOT_BASE_URL=https://sqlbot.example.com
SQLBOT_APP_ID=
SQLBOT_APP_SECRET=
SQLBOT_EMBEDDED_ID=
SQLBOT_EMBED_ACCOUNT=receivables-internal
